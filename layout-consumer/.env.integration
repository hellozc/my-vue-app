# 联调模式（npm run dev:h5:api / dev:mp-weixin:api）
# H5 走 Vite 代理；小程序/App 用 VITE_API_TARGET + VITE_API_BASE_URL 拼完整地址

VITE_USE_MOCK=false

VITE_API_BASE_URL=/api
VITE_API_TARGET=http://localhost:8080

# 真机调试请复制为 .env.integration.local，改为局域网 IP，例如：
# VITE_API_TARGET=http://192.168.1.100:8080

VITE_LAYOUT_CODE=demo-home
VITE_API_TIMEOUT=15000
VITE_API_SUCCESS_CODE=200
