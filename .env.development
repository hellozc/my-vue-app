# Mock 开发环境（npm run dev / npm run dev:mock）
# 若存在 .env.development.local，会覆盖本文件中的同名变量
VITE_USE_MOCK=true

# 请求基础路径（前端 axios baseURL）
VITE_API_BASE_URL=/api

# 请求超时（毫秒）
VITE_API_TIMEOUT=10000

# 联调后端地址（VITE_USE_MOCK=false 时 vite 代理转发到此地址）
VITE_API_TARGET=http://localhost:8080

# 联调时若后端不带 /api 前缀，设为 true（/api/user → /user）
VITE_API_STRIP_PREFIX=false

# 业务成功状态码
VITE_API_SUCCESS_CODE=200
